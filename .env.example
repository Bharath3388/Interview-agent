# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── LLM (Groq) ──
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ── TTS ──
TTS_VOICE=af_heart
TTS_LANGUAGE=a

# ── Interview defaults ──
MAX_FOLLOW_UPS=2
DEFAULT_DURATION=15

# ── Database ──
# DATABASE_URL=sqlite:///interview_agent.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/interview_agent

# ── Auth / JWT ──
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRE_MINUTES=10080

# ── CORS ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Temp ──
TEMP_DIR=/tmp/interview_bot
